# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# AI Provider Selection: openrouter, gemini, or openai
AI_PROVIDER=openrouter
AI_API_KEY=your_ai_api_key_here
AI_MODEL=meta-llama/llama-3.1-405b-instruct # Recommended for reasoning

# Web Search Configuration
TAVILY_API_KEY=your_tavily_api_key_here
# Fallback search if Tavily is unavailable (optional)
SEARCH_ENGINE=tavily

# GIF Integration
TENOR_API_KEY=your_tenor_api_key_here
GIPHY_API_KEY=your_giphy_api_key_here

# Bot Settings
DEFAULT_PREFIX=!
ADMIN_USER_ID=your_discord_id_here
LOG_CHANNEL_ID=your_log_channel_id_here
VERBOSE_MODE=true
MEMORY_DEPTH=20
