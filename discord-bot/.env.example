# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here

# AI Configuration (Optional)
AI_API_KEY=your_ai_api_key_here
AI_PROVIDER=openrouter
AI_MODEL=microsoft/wizardlm-2-8x22b

# Database Configuration
# Use SQLite for history storage
USE_SQLITE=true

# Backup Configuration
BACKUP_INTERVAL_HOURS=6

# Command Analysis
COMMAND_ANALYSIS_INTERVAL_HOURS=24

# Sync Commands on Startup
SYNC_COMMANDS=false

# Alert Channel for Critical Errors (Optional)
ALERT_CHANNEL_ID=your_channel_id_here

# Encryption Key (Auto-generated if not provided)
# ENCRYPTION_KEY=your_encryption_key_here